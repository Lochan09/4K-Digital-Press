{
  "name": "4k-digital-press",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "nodemon --watch server --ext ts,js,json --exec \"node --experimental-specifier-resolution=node server/index.js\"",
    "build": "node node_modules/vite/bin/vite.js build",
    "preview": "vite preview",
    "start": "node server/index.js"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase": "^12.13.0",
    "googleapis": "^172.0.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.8",
    "nodemon": "^3.1.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  }
}
