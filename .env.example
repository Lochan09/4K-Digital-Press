# ── Firebase Authentication ───────────────────────────────
VITE_FIREBASE_API_KEY=          # from Firebase console → Project settings → Your apps
VITE_FIREBASE_AUTH_DOMAIN=      # yourproject.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=       # your-project-id
VITE_FIREBASE_APP_ID=           # 1:123456:web:abcdef
VITE_OWNER_EMAIL=4kdigitalpress@gmail.com

# ── Google OAuth2 (Drive) ─────────────────────────────────
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:5174/auth/callback
OAUTH_REFRESH_TOKEN=        # paste from data/auth.json after visiting /auth/setup

# ── Google Drive ──────────────────────────────────────────
DRIVE_PARENT_FOLDER_ID=     # folder ID from Drive URL

# ── Gmail notifications ───────────────────────────────────
GMAIL_USER=your@gmail.com
GMAIL_PASS=                 # 16-char App Password (not account password)
OWNER_EMAIL=your@gmail.com  # where order emails are sent

# ── Server ────────────────────────────────────────────────
PORT=5174
